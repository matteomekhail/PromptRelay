# Convex
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# Convex Auth JWT signing.
# Generate an RSA private key for production, for example:
# openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 | base64
CONVEX_AUTH_PRIVATE_KEY=
CONVEX_AUTH_KEY_ID=promptrelay-convex-auth

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Volunteer CLI defaults
PROMPTRELAY_APP_URL=http://localhost:3000
PROMPTRELAY_CONVEX_URL=
PROMPTRELAY_GITHUB_CLIENT_ID=
PROMPTRELAY_ALLOW_UNSAFE_EXECUTION=0

# GitHub App (for slash commands in issues/PRs)
# Create a GitHub App at https://github.com/settings/apps
# Give it permissions: metadata (read), issues (read/write),
# pull requests (read/write), contents (read/write)
# Set webhook URL to: https://your-domain.com/api/github/webhook
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
