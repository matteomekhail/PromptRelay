# Convex
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# GitHub OAuth (create at https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Auth.js / NextAuth
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GitHub App (for slash commands in issues/PRs)
# Create a GitHub App at https://github.com/settings/apps
# Give it permissions: issues (read/write), pull requests (read), comments (read/write)
# Set webhook URL to: https://your-domain.com/api/github/webhook
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_TOKEN=
